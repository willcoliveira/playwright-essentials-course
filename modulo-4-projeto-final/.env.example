# Copy this file to `.env` and adjust as needed. `.env` is gitignored — never commit real secrets.
#
# Base URL under test. Leave unset to use the public SauceDemo demo.
# Override to point the same suite at a staging or preview environment.
BASE_URL=https://www.saucedemo.com

# SauceDemo credentials are public demo values and live in data/users.ts, so they
# are NOT required here. In a real project the password would come from an env var:
# SAUCEDEMO_PASSWORD=secret_sauce
