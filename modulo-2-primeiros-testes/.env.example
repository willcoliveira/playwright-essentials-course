# Copy to `.env` and adjust. `.env` is gitignored — never commit it.
# These are the public SauceDemo demo values; the specs fall back to them if unset,
# so the suite runs green out of the box even without a .env file.
BASE_URL=https://www.saucedemo.com
STANDARD_USER=standard_user
LOCKED_OUT_USER=locked_out_user
SAUCEDEMO_PASSWORD=secret_sauce
